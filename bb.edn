{:paths ["."],
  :deps #:cheshire{cheshire #:mvn{:version "5.13.0"}},
  :tasks
  {serve
   {:doc
    "Start the Pinboard MCP server (PINBOARD_MCP_PORT env or OS-assigned)",
    :task (shell "bb pinboard_mcp.bb")},

   start
   {:doc "Start on port 3030 (or PINBOARD_MCP_PORT) for local dev",
    :task
    (shell
     {:env
      (merge
       (into {} (System/getenv))
       {"PINBOARD_MCP_PORT" (or (System/getenv "PINBOARD_MCP_PORT") "3030")})}
     "bb pinboard_mcp.bb")},
   test
   {:doc "Run integration tests (fake API, no real credentials)",
    :task (shell "bb tests/test_pinboard_mcp.clj")},
   test-staging
   {:doc "Run staging tests against real Pinboard API. Requires PINBOARD_TEST_TOKEN",
    :task (shell "bb tests/test_pinboard_mcp_staging.clj")},
   lint
   {:doc "Lint with clj-kondo",
    :task (shell "clj-kondo --lint pinboard_mcp.bb")},
   health
   {:doc "Health check against running server (set PINBOARD_MCP_PORT)",
    :task
    (shell
     (str
      "curl -sf http://127.0.0.1:"
      (or (System/getenv "PINBOARD_MCP_PORT") "3030")
      "/health | jq ."))}}}
